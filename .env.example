# ===== 必填 =====
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER/DATABASE
# 正式環境至少 32 個隨機字元
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters

# ===== 網站與登入 =====
NODE_ENV=production
APP_BASE_URL=https://defect-system-render.onrender.com
# 多個來源以逗號分隔
ALLOWED_ORIGINS=https://defect-system-render.onrender.com
JWT_EXPIRES_IN=4h
# 正式展示帳號建立完成後，建議改為 false
ALLOW_PUBLIC_REGISTRATION=true
# 留空代表不要求；設定後註冊頁必須輸入相同邀請碼
REGISTRATION_INVITE_CODE=

# ===== MQTT / HiveMQ =====
MQTT_URL=mqtts://YOUR_CLUSTER.s1.eu.hivemq.cloud
MQTT_PORT=8883
HIVEMQ_USER=
HIVEMQ_PASS=
MQTT_REPORT_TOPIC=factory/defect/report
# {system_id} 會替換成實際機台 ID
MQTT_ESTOP_TOPIC_TEMPLATE=factory/control/estop/{system_id}
MQTT_ESTOP_ACK_TOPIC=factory/control/estop/ack/+

# ===== Brevo SMTP（登入驗證碼與 NG 警報） =====
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=2525
BREVO_SMTP_SECURE=false
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
BREVO_SENDER_EMAIL=
ALERT_EMAIL=
OTP_TTL_MINUTES=5
OTP_RESEND_SECONDS=60
OTP_MAX_ATTEMPTS=5

# ===== NG 警報規則 =====
ALERT_THRESHOLD=3
ALERT_WINDOW_MINUTES=10
ALERT_COOLDOWN_MINUTES=30

# ===== Gemini API =====
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
AI_REQUESTS_PER_MINUTE=10

# 僅本機測試；正式環境不可開啟
DEV_RETURN_OTP=false
