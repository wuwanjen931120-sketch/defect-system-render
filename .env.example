# ===== 必填 =====
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER/DATABASE
# 正式環境至少 32 個隨機字元
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters

# ===== 網站與登入 =====
NODE_ENV=production
APP_BASE_URL=https://defect-system-render.onrender.com
# 多個來源以逗號分隔
ALLOWED_ORIGINS=https://defect-system-render.onrender.com
JWT_EXPIRES_IN=4h
JWT_COOKIE_MAX_AGE_SECONDS=14400
AUTH_COOKIE_NAME=defect_session
# 正式展示帳號建立完成後，建議改為 false
ALLOW_PUBLIC_REGISTRATION=true
# 留空代表不要求；設定後註冊頁必須輸入相同邀請碼
REGISTRATION_INVITE_CODE=

# ===== MQTT / HiveMQ =====
MQTT_URL=mqtts://YOUR_CLUSTER.s1.eu.hivemq.cloud
MQTT_PORT=8883
HIVEMQ_USER=
HIVEMQ_PASS=
MQTT_REPORT_TOPIC=factory/defect/report
# {system_id} 會替換成實際機台 ID
MQTT_ESTOP_TOPIC_TEMPLATE=factory/control/estop/{system_id}
MQTT_ESTOP_ACK_TOPIC=factory/control/estop/ack/+

# ===== SMTP（登入驗證碼與 NG 警報） =====
# Brevo：SMTP_PROVIDER=brevo、HOST=smtp-relay.brevo.com、PORT=2525、SECURE=false
# Gmail：SMTP_PROVIDER=gmail、HOST=smtp.gmail.com、PORT=465、SECURE=true，PASS 必須是應用程式密碼
SMTP_PROVIDER=brevo
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ALERT_EMAIL=
OTP_TTL_MINUTES=5
OTP_RESEND_SECONDS=60
OTP_MAX_ATTEMPTS=5

# 舊 Render 變數相容性；新部署不用重複填
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=2525
BREVO_SMTP_SECURE=false
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
BREVO_SENDER_EMAIL=
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ===== NG 警報規則 =====
ALERT_THRESHOLD=3
ALERT_WINDOW_MINUTES=10
ALERT_COOLDOWN_MINUTES=30

# ===== Gemini API 免費層 =====
# API Key 只放 Render Environment，不可寫入前端或 GitHub
GEMINI_API_KEY=
# 2026-07 官方定價頁列為可使用免費層的 Flash 穩定模型
GEMINI_MODEL=gemini-3.6-flash
AI_REQUESTS_PER_MINUTE=5
AI_REQUESTS_PER_DAY=100

# ===== 資料保留 =====
# 0 代表不自動刪除；設定正整數後每天清理超過天數的資料
DEFECT_RETENTION_DAYS=0
AUDIT_RETENTION_DAYS=0

# 僅本機測試；正式環境不可開啟
DEV_RETURN_OTP=false
