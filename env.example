# ===== 必填 =====
MONGODB_URI=
JWT_SECRET=

# ===== MQTT / HiveMQ =====
HIVEMQ_USER=
HIVEMQ_PASS=

# ===== Brevo SMTP：登入驗證碼與 NG 警示 =====
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
BREVO_SMTP_PORT=2525
BREVO_SENDER_EMAIL=
ALERT_EMAIL=

# ===== Gemini AI：未設定時自動使用本機統計備援 =====
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# ===== 網站與安全設定 =====
NODE_ENV=production
CORS_ORIGINS=https://defect-system-render.onrender.com
ALLOW_PASSWORD_LOGIN=false
# 設定後，公開註冊必須提供相同 invite_code；留空表示不要求邀請碼。
REGISTRATION_INVITE_CODE=

# ===== NG 時間窗警示 =====
ALERT_THRESHOLD=3
ALERT_WINDOW_MINUTES=10
ALERT_COOLDOWN_MINUTES=10
